{
"compilerOptions": {
"target": "es2020",
"module": "commonjs",
"lib": ["es2018"],
"outDir": "./dist",
"rootDir": "./",
"strict": false,
"esModuleInterop": true,
"resolveJsonModule": true,
"skipLibCheck": true,
"forceConsistentCasingInFileNames": true
},
"include": ["**/*.ts", "_helpers/swagger.js"],
"exclude": ["node_modules"]
}